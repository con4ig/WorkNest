# EditorConfig — keeps whitespace consistent across editors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,mdx}]
indent_size = 4

[client/**.{js,jsx}]
indent_size = 4

[server/**.{js,jsx}]
indent_size = 2

[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 4

[Dockerfile]
indent_size = 4

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
indent_size = 4
